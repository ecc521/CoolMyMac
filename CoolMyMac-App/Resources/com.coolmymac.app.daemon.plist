<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Label must exactly match the bundle identifier -->
    <key>Label</key>
    <string>com.coolmymac.app.daemon</string>

    <!-- Path to the daemon binary inside the App bundle.
         SMAppService resolves this relative to the App bundle root. -->
    <key>BundleProgram</key>
    <string>Contents/Library/LaunchDaemons/CoolMyMac-Daemon</string>

    <!-- XPC Mach service name — must match CoolMyMacXPCServiceName -->
    <key>MachServices</key>
    <dict>
        <key>com.coolmymac.app.daemon</key>
        <true/>
    </dict>

    <!-- Run as root to allow SMC writes -->
    <key>RunAtLoad</key>
    <true/>

    <!-- Keep the daemon alive if it crashes, but allow it to gracefully auto-suspend with exit(0) -->
    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>

    <!-- Give the daemon high scheduling priority -->
    <key>ProcessType</key>
    <string>Interactive</string>

    <!-- Standard I/O to system log -->
    <key>StandardOutPath</key>
    <string>/var/log/com.coolmymac.daemon.log</string>
    <key>StandardErrorPath</key>
    <string>/var/log/com.coolmymac.daemon.error.log</string>
</dict>
</plist>
