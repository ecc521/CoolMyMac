+
+struct SensorRowView: View {
+    let sensor: SensorReading
+    let group: SensorGroup
+    @Bindable var state: AppState
+    let decimalResolution: Int
+    
+    var body: some View {
+        let isExcluded = state.excludedSensors.contains(sensor.name) || !state.activeSensors.contains(group)
+        let isHot = sensor.celsius > 80
+        let format = decimalResolution == 1 ? "%.1f°C" : "%.0f°C"
+        
+        HStack {
+            Toggle("", isOn: Binding(
+                get: { !state.excludedSensors.contains(sensor.name) },
+                set: { isOn in
+                    if isOn { state.excludedSensors.remove(sensor.name) }
+                    else { state.excludedSensors.insert(sensor.name) }
+                }
+            ))
+            .labelsHidden()
+            .controlSize(.mini)
+            .tint(.blue)
+            .disabled(!state.activeSensors.contains(group))
+            
+            Text(sensor.name)
+                .font(.system(size: 12))
+                .opacity(isExcluded ? 0.5 : 1.0)
+                
+            Spacer()
+            
+            Text(String(format: format, sensor.celsius))
+                .font(.system(size: 12, design: .monospaced))
+                .foregroundStyle(isHot ? Color.orange : Color.primary)
+                .opacity(isExcluded ? 0.5 : 1.0)
+        }
+        .padding(.vertical, 2)
+    }
+}
