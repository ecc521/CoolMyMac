+                floatBits |= UInt32(val.bytes[0])
+                floatBits |= UInt32(val.bytes[1]) << 8
+                floatBits |= UInt32(val.bytes[2]) << 16
+                floatBits |= UInt32(val.bytes[3]) << 24
